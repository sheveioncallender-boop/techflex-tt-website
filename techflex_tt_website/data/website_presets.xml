<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Keep Odoo's native shop engine; set the approved four-column desktop grid and enable its category filter. -->
    <record id="website.default_website" model="website">
        <field name="shop_ppr">4</field>
        <field name="shop_ppg">20</field>
    </record>
    <record id="website_sale.products_categories" model="ir.ui.view">
        <field name="active" eval="True"/>
    </record>
</odoo>

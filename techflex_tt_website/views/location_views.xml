<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_techflex_location_list" model="ir.ui.view">
        <field name="name">techflex.location.list</field><field name="model">techflex.location</field>
        <field name="arch" type="xml"><list><field name="sequence" widget="handle"/><field name="name"/><field name="island"/><field name="phone"/><field name="email"/><field name="active"/></list></field>
    </record>
    <record id="view_techflex_location_form" model="ir.ui.view">
        <field name="name">techflex.location.form</field><field name="model">techflex.location</field>
        <field name="arch" type="xml"><form><sheet><group><field name="image_1920" widget="image" class="oe_avatar"/><group><field name="name"/><field name="island"/><field name="phone"/><field name="email"/><field name="map_url"/><field name="sequence"/><field name="active"/><field name="website_id"/></group></group><group><field name="address"/><field name="business_hours"/></group></sheet></form></field>
    </record>
    <record id="action_techflex_location" model="ir.actions.act_window"><field name="name">Locations</field><field name="res_model">techflex.location</field><field name="view_mode">list,form</field></record>
    <menuitem id="menu_techflex_locations" name="Locations" parent="menu_techflex_content" action="action_techflex_location" sequence="20"/>
</odoo>

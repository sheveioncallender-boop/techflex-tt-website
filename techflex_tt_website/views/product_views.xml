<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_techflex" model="ir.ui.view">
        <field name="name">product.template.form.techflex.website</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="priority">60</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="TechFlex Website" name="techflex_website">
                    <group>
                        <group string="Website Merchandising">
                            <field name="techflex_monthly_special"/>
                            <field name="techflex_condition"/>
                            <field name="techflex_show_details"/>
                        </group>
                        <group string="Warranty &amp; Support">
                            <field name="techflex_warranty_label"/>
                            <field name="techflex_warranty_months"/>
                            <field name="techflex_support_note"/>
                            <field name="techflex_delivery_note"/>
                        </group>
                    </group>
                    <group string="Warranty Details"><field name="techflex_warranty_details" nolabel="1" widget="html"/></group>
                    <group string="Key Highlights">
                        <field name="techflex_highlight_line_ids" nolabel="1">
                            <list editable="bottom"><field name="sequence" widget="handle"/><field name="name"/></list>
                        </field>
                    </group>
                    <group string="Technical Specifications">
                        <field name="techflex_spec_line_ids" nolabel="1">
                            <list editable="bottom"><field name="sequence" widget="handle"/><field name="section"/><field name="name"/><field name="value"/><field name="show_on_website"/></list>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

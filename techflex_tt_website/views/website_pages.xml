<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="tf_section_heading">
        <div class="tf-section-heading"><span></span><h2><t t-out="title"/></h2><span></span></div>
    </template>

    <template id="page_home" name="TechFlex Homepage">
        <t t-call="website.layout">
            <t t-set="additional_title">Affordable Tech. Exceptional Service.</t>
            <div id="wrap" class="tf-page tf-home-page">
                <section class="tf-hero tf-home-hero">
                    <div class="tf-hero-copy">
                        <p class="tf-eyebrow">TECHFLEX TT LIMITED</p>
                        <h1>AFFORDABLE TECH.<br/><em>EXCEPTIONAL SERVICE.</em></h1>
                        <p>Laptops, desktops, printers, networking and trusted technology support across Trinidad &amp; Tobago.</p>
                        <div class="tf-button-row"><a class="tf-button tf-button-orange" href="/shop">Shop Devices <i class="fa fa-arrow-right"/></a><a class="tf-button tf-button-outline" href="/contact-us">Get Support <i class="fa fa-arrow-right"/></a></div>
                        <div class="tf-mini-benefits"><span><i class="fa fa-shield"/> Quality Products</span><span><i class="fa fa-certificate"/> Expert Service</span><span><i class="fa fa-truck"/> Fast Delivery</span><span><i class="fa fa-check-circle"/> Warranty</span></div>
                    </div>
                    <div class="tf-hero-media"><img src="/techflex_tt_website/static/src/img/home_hero.webp" alt="TechFlex colourful laptops showroom"/><div class="tf-wedge tf-wedge-right"/></div>
                </section>

                <section class="tf-container tf-service-grid tf-lifted-grid">
                    <a class="tf-service-card" href="/shop"><i class="fa fa-shopping-cart"/><div><h3>Sales</h3><p>Top brands, great prices and the latest technology.</p><strong>Shop Now →</strong></div></a>
                    <a class="tf-service-card orange" href="/rentals"><i class="fa fa-calendar"/><div><h3>Rentals</h3><p>Flexible rental plans for work, events and schools.</p><strong>Learn More →</strong></div></a>
                    <a class="tf-service-card" href="/contact-us"><i class="fa fa-headphones"/><div><h3>Product Support</h3><p>Friendly guidance before, during and after purchase.</p><strong>Get Help →</strong></div></a>
                    <a class="tf-service-card orange" href="/contact-us"><i class="fa fa-briefcase"/><div><h3>Corporate Enquiries</h3><p>Scalable technology supply for teams and institutions.</p><strong>Contact Us →</strong></div></a>
                </section>

                <section class="tf-section tf-container">
                    <t t-call="techflex_tt_website.tf_section_heading"><t t-set="title">SHOP BY CATEGORY</t></t>
                    <p class="tf-section-subtitle">Everything you need, all in one place.</p>
                    <div class="tf-category-grid">
                        <a href="/shop" class="tf-category-card"><i class="fa fa-laptop"/><h3>Laptops</h3><span>View All →</span></a>
                        <a href="/shop" class="tf-category-card"><i class="fa fa-desktop"/><h3>Desktops</h3><span>View All →</span></a>
                        <a href="/shop" class="tf-category-card"><i class="fa fa-print"/><h3>Printers</h3><span>View All →</span></a>
                        <a href="/shop" class="tf-category-card"><i class="fa fa-wifi"/><h3>Networking</h3><span>View All →</span></a>
                        <a href="/shop" class="tf-category-card"><i class="fa fa-headphones"/><h3>Accessories</h3><span>View All →</span></a>
                    </div>
                </section>

                <section class="tf-section tf-specials-section">
                    <div class="tf-container">
                        <div class="tf-title-with-link"><t t-call="techflex_tt_website.tf_section_heading"><t t-set="title">MONTHLY SPECIALS</t></t><a href="/shop">View All Specials →</a></div>
                        <div class="tf-product-row" t-if="monthly_specials">
                            <article class="tf-home-product" t-foreach="monthly_specials" t-as="product">
                                <a t-att-href="product.website_url"><div class="tf-sale-badge">SPECIAL</div><img t-att-src="'/web/image/product.template/%s/image_512' % product.id" t-att-alt="product.name"/><h3 t-out="product.name"/><p t-if="product.techflex_condition" class="tf-product-condition" t-out="dict(product._fields['techflex_condition'].selection).get(product.techflex_condition)"/><div class="tf-price"><span t-out="monthly_special_prices.get(product.id, {}).get('price_reduce', 0.0)" t-options='{"widget":"monetary","display_currency":request.website.currency_id}'/></div></a>
                            </article>
                        </div>
                        <div class="tf-empty-products" t-else="">Publish products in Odoo and mark selected items as Monthly Specials.</div>
                    </div>
                </section>

                <section class="tf-container tf-audience-strip"><div><h2>TECH FOR WORK.<br/>TECH FOR LIFE.<br/><em>TECH FOR EVERYONE.</em></h2><p>From school to business, from home to gaming.</p></div><div class="tf-audience-items"><span><i class="fa fa-briefcase"/><b>For Work</b></span><span><i class="fa fa-graduation-cap"/><b>For School</b></span><span><i class="fa fa-home"/><b>For Home</b></span><span><i class="fa fa-gamepad"/><b>For Play</b></span></div></section>

                <section class="tf-section tf-container">
                    <div class="tf-feature-panels"><a href="/contact-us" style="background-image:url('/techflex_tt_website/static/src/img/store_desktops.webp')"><span><i class="fa fa-headphones"/> Product Support</span></a><a href="/shop" style="background-image:url('/techflex_tt_website/static/src/img/store_laptops.webp')"><span><i class="fa fa-gamepad"/> Gaming &amp; Performance</span></a><a href="/rentals" style="background-image:url('/techflex_tt_website/static/src/img/meeting_room.webp')"><span><i class="fa fa-calendar"/> Technology Rentals</span></a></div>
                </section>

                <section class="tf-section tf-container">
                    <t t-call="techflex_tt_website.tf_section_heading"><t t-set="title">WHY CHOOSE TECHFLEX TT?</t></t>
                    <div class="tf-about-grid"><div><p class="tf-eyebrow orange">ABOUT US</p><h2>Your trusted tech partner in Trinidad &amp; Tobago</h2><p>We combine quality products, expert guidance and dependable service to keep individuals, families and organisations connected.</p><ul class="tf-check-list"><li>Modern technology showroom</li><li>Friendly, knowledgeable team</li><li>After-sales care you can count on</li></ul><a class="tf-button tf-button-orange" href="/about-us">Learn More</a></div><img src="/techflex_tt_website/static/src/img/store_floor.webp" alt="TechFlex showroom"/></div>
                </section>

                <section class="tf-section tf-container">
                    <t t-call="techflex_tt_website.tf_section_heading"><t t-set="title">OUR LOCATIONS</t></t>
                    <div class="tf-location-grid"><article class="tf-location-card" t-foreach="locations" t-as="location"><img t-att-src="'/web/image/techflex.location/%s/image_1920' % location.id" t-att-alt="location.name"/><div><h3 t-out="location.name"/><p t-out="location.address"/><p><i class="fa fa-phone"/> <span t-out="location.phone"/></p><a t-att-href="location.map_url or '#'">View Location →</a></div></article></div>
                </section>

                <section class="tf-section tf-testimonials"><div class="tf-container"><t t-call="techflex_tt_website.tf_section_heading"><t t-set="title">WHAT OUR CUSTOMERS SAY</t></t><div class="tf-testimonial-grid"><blockquote>“Excellent service and great prices. The team made finding the right laptop easy.”<strong>— Retail Customer</strong></blockquote><blockquote>“Professional, reliable support for our office technology requirements.”<strong>— Corporate Customer</strong></blockquote><blockquote>“Knowledgeable staff and a wide range of quality technology products.”<strong>— Tobago Customer</strong></blockquote></div></div></section>
            </div>
        </t>
    </template>

    <template id="page_rentals" name="TechFlex Rentals">
        <t t-call="website.layout"><t t-set="additional_title">Technology Rentals</t><div id="wrap" class="tf-page tf-rentals-page">
            <section class="tf-hero tf-inner-hero tf-rental-hero"><div class="tf-hero-copy"><p class="tf-eyebrow">TECHFLEX TT RENTALS</p><h1>TECH RENTALS.<br/><em>SMART SOLUTIONS.</em></h1><p>Reliable technology rentals for businesses, events, schools and temporary needs across Trinidad &amp; Tobago.</p><div class="tf-mini-benefits"><span><i class="fa fa-shield"/> Flexible Terms</span><span><i class="fa fa-users"/> Business Friendly</span><span><i class="fa fa-truck"/> Fast Delivery</span><span><i class="fa fa-headphones"/> Reliable Support</span></div></div><div class="tf-hero-media"><img src="/techflex_tt_website/static/src/img/rental_hero.webp" alt="TechFlex rental equipment"/><div class="tf-wedge tf-wedge-right"/></div></section>
            <section class="tf-section tf-container tf-rental-content">
                <div class="tf-form-card">
                    <h2>RENTAL REQUEST FORM</h2>
                    <div t-if="submitted" class="alert alert-success">Thank you. Your rental request was submitted successfully.</div>
                    <div t-if="error" class="alert alert-danger">Please check the required fields and try again.</div>
                    <form action="/techflex/rental/submit" method="post" class="tf-form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <h3>CONTACT INFORMATION</h3><div class="tf-form-grid three"><label>First Name *<input name="first_name" required="required"/></label><label>Last Name *<input name="last_name" required="required"/></label><label>Company Name<input name="company_name"/></label></div>
                        <div class="tf-form-grid two"><label>Email Address *<input type="email" name="email" required="required"/></label><label>Phone Number *<input type="tel" name="phone" required="required"/></label></div>
                        <label>Business Address *<textarea name="business_address" required="required" rows="3"></textarea></label>
                        <h3>EQUIPMENT &amp; REQUIREMENTS</h3><div class="tf-checkbox-grid"><label><input type="checkbox" name="equipment_desktops"/> Desktops</label><label><input type="checkbox" name="equipment_laptops"/> Laptops</label><label><input type="checkbox" name="equipment_tablets"/> Tablets</label><label><input type="checkbox" name="equipment_tvs"/> TVs / Monitors</label><label><input type="checkbox" name="equipment_projectors"/> Projectors</label><label><input type="checkbox" name="equipment_printers"/> Printers</label><label><input type="checkbox" name="equipment_accessories"/> Accessories / Peripherals</label><label>Other <input name="equipment_other"/></label></div>
                        <div class="tf-form-grid two"><fieldset><legend>Specification Level *</legend><label class="inline"><input type="radio" name="specification_level" value="basic" required="required"/> Basic</label><label class="inline"><input type="radio" name="specification_level" value="mid"/> Mid Range</label><label class="inline"><input type="radio" name="specification_level" value="high"/> High End</label></fieldset><label>Number of Units (1–65) *<input type="number" min="1" max="65" name="number_of_units" required="required" value="1"/></label></div>
                        <h3>RENTAL DETAILS</h3><div class="tf-form-grid three"><label>Rental Start Date *<input type="date" name="rental_start_date" required="required"/></label><label>Rental End Date<input type="date" name="rental_end_date"/></label><label>Duration<input name="rental_duration" placeholder="e.g. 2 weeks"/></label></div>
                        <label>Pickup or Delivery *<select name="pickup_delivery" required="required"><option value="">Select an option</option><option value="pickup">Pickup</option><option value="delivery">Delivery</option><option value="either">Either</option></select></label>
                        <h3>ADDITIONAL INFORMATION</h3><label>Additional Information / Requirements<textarea name="additional_info" rows="4"></textarea></label>
                        <button class="tf-button tf-button-orange tf-submit" type="submit">Submit Rental Request <i class="fa fa-paper-plane"/></button>
                    </form>
                </div>
                <aside class="tf-rental-aside"><div class="tf-promo-image"><img src="/techflex_tt_website/static/src/img/store_desktops.webp" alt="Long and short term rentals"/><div><h2>LONG TERM &amp;<br/>SHORT TERM</h2><p>Rentals available.</p></div></div>
                    <div class="tf-faq-card"><h2>FREQUENTLY ASKED QUESTIONS</h2><div class="accordion" id="rentalFaq"><div class="accordion-item"><h3 class="accordion-header"><button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#rf1">What equipment is available?</button></h3><div id="rf1" class="accordion-collapse collapse show" data-bs-parent="#rentalFaq"><div class="accordion-body">Laptops, desktops, tablets, projectors, printers, displays and selected accessories.</div></div></div><div class="accordion-item"><h3 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#rf2">How many units can I request?</button></h3><div id="rf2" class="accordion-collapse collapse" data-bs-parent="#rentalFaq"><div class="accordion-body">Rental requests can include between 1 and 65 units, subject to availability.</div></div></div><div class="accordion-item"><h3 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#rf3">Do you offer delivery and pickup?</button></h3><div id="rf3" class="accordion-collapse collapse" data-bs-parent="#rentalFaq"><div class="accordion-body">Delivery and pickup options are available across Trinidad &amp; Tobago.</div></div></div><div class="accordion-item"><h3 class="accordion-header"><button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#rf4">Is technical support included?</button></h3><div id="rf4" class="accordion-collapse collapse" data-bs-parent="#rentalFaq"><div class="accordion-body">Support options are tailored to the rental package and requirements.</div></div></div></div></div>
                </aside>
            </section>
            <section class="tf-cta-bar tf-container"><div><i class="fa fa-calendar"/><span><b>NEED EQUIPMENT FAST?</b><small>Request availability and a package tailored to your needs.</small></span></div><a class="tf-button tf-button-orange" href="#top">Request a Quote</a><a class="tf-button tf-button-outline-light" href="tel:+18682354919">Call Now</a></section>
        </div></t>
    </template>

    <template id="page_about" name="TechFlex About Us">
        <t t-call="website.layout"><t t-set="additional_title">About TechFlex</t><div id="wrap" class="tf-page tf-about-page">
            <section class="tf-hero tf-inner-hero"><div class="tf-hero-copy"><p class="tf-eyebrow">ABOUT TECHFLEX</p><h1>DRIVEN BY TECHNOLOGY.<br/><em>COMMITTED TO YOU.</em></h1><p>A Trinidad &amp; Tobago technology company dedicated to quality products, reliable rentals and exceptional customer service.</p><div class="tf-mini-benefits"><span><i class="fa fa-certificate"/> Quality Products</span><span><i class="fa fa-handshake-o"/> Trusted Service</span><span><i class="fa fa-users"/> Customer Focused</span><span><i class="fa fa-shield"/> Reliable Support</span></div></div><div class="tf-hero-media"><img src="/techflex_tt_website/static/src/img/about_hero.webp" alt="TechFlex team and showroom"/><div class="tf-wedge tf-wedge-right"/></div></section>
            <section class="tf-section tf-container tf-story-card"><img src="/techflex_tt_website/static/src/img/store_floor.webp" alt="TechFlex showroom"/><div><p class="tf-eyebrow orange">OUR STORY</p><h2>TECH SOLUTIONS MADE SIMPLE.</h2><p>TechFlex TT Limited was built around a simple mission: make technology accessible, dependable and easier to purchase or rent. We serve individuals, businesses, schools and institutions with practical solutions and helpful guidance.</p><p>Whether you need the latest products, short-term technology for an event, or advice selecting the right equipment, our team is ready to help.</p><a class="tf-button tf-button-blue" href="/contact-us">Contact Our Team</a></div></section>
            <section class="tf-section tf-container"><h2 class="tf-left-heading">WHY CHOOSE TECHFLEX?</h2><div class="tf-value-grid"><article><i class="fa fa-check-circle"/><h3>Quality You Can Trust</h3><p>Reliable products from leading technology brands.</p></article><article><i class="fa fa-tags"/><h3>Affordable Solutions</h3><p>Competitive options for different needs and budgets.</p></article><article><i class="fa fa-headphones"/><h3>Exceptional Service</h3><p>A helpful local team ready to guide you.</p></article><article><i class="fa fa-truck"/><h3>Fast &amp; Reliable</h3><p>Delivery, rentals and dependable support.</p></article></div></section>
            <section class="tf-section tf-container"><h2 class="tf-left-heading">MEET OUR TEAM</h2><div class="tf-team-grid"><article class="tf-team-card" t-foreach="team_members" t-as="member"><img t-att-src="'/web/image/techflex.team.member/%s/image_1920' % member.id" t-att-alt="member.name"/><div><h3 t-out="member.name"/><p class="tf-role" t-out="member.job_title"/><p t-if="member.short_bio" t-out="member.short_bio"/></div></article></div></section>
            <section class="tf-cta-bar tf-container"><div><i class="fa fa-comments"/><span><b>HAVE QUESTIONS?</b><small>Our team is ready to help with products and services.</small></span></div><a class="tf-button tf-button-orange" href="/contact-us">Contact Us Today</a><a class="tf-button tf-button-outline-light" href="tel:+18682354919">+1 (868) 235-4919</a></section>
        </div></t>
    </template>

    <template id="page_contact" name="TechFlex Contact Us">
        <t t-call="website.layout"><t t-set="additional_title">Contact TechFlex</t><div id="wrap" class="tf-page tf-contact-page">
            <section class="tf-hero tf-inner-hero"><div class="tf-hero-copy"><p class="tf-eyebrow">CONTACT TECHFLEX</p><h1>WE’RE HERE<br/><em>TO HELP.</em></h1><p>Have a question, need a quote or want product advice? Our team can assist with sales, rentals, orders and general enquiries.</p></div><div class="tf-hero-media"><img src="/techflex_tt_website/static/src/img/contact_hero.webp" alt="TechFlex showroom assistance"/><div class="tf-wedge tf-wedge-right"/></div></section>
            <section class="tf-container tf-contact-benefits"><article><i class="fa fa-clock-o"/><h3>Fast Response</h3><p>We aim to respond within one business day.</p></article><article><i class="fa fa-smile-o"/><h3>Friendly Support</h3><p>Approachable, knowledgeable local assistance.</p></article><article><i class="fa fa-map-marker"/><h3>Two Locations</h3><p>Serving customers in Trinidad and Tobago.</p></article><article><i class="fa fa-headphones"/><h3>Sales &amp; Rental Help</h3><p>Product guidance, rentals and order assistance.</p></article></section>
            <section class="tf-section tf-container tf-contact-layout"><div class="tf-form-card"><h2>SEND US A MESSAGE</h2><div t-if="submitted" class="alert alert-success">Thank you. Your message was sent successfully.</div><div t-if="error" class="alert alert-danger">Please complete all required fields.</div><form class="tf-form" action="/techflex/contact/submit" method="post"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><div class="tf-form-grid three"><label>Full Name *<input name="full_name" required="required"/></label><label>Email Address *<input type="email" name="email" required="required"/></label><label>Phone Number *<input type="tel" name="phone" required="required"/></label></div><div class="tf-form-grid two"><label>Subject *<input name="subject" required="required"/></label><label>Department *<select name="department" required="required"><option value="">Select department</option><option value="sales">Sales</option><option value="rentals">Rentals</option><option value="orders">Orders &amp; Delivery</option><option value="support">Support &amp; Advice</option><option value="general">General Enquiry</option></select></label></div><label>Message *<textarea name="message" rows="6" required="required"></textarea></label><button type="submit" class="tf-button tf-button-orange">Send Message <i class="fa fa-paper-plane"/></button></form></div>
                <aside class="tf-contact-side"><div class="tf-info-card"><h2>CONTACT DETAILS</h2><p><i class="fa fa-phone"/> <b>+1 (868) 235-4919</b></p><p><i class="fa fa-envelope"/> info@techflextt.com</p><p><i class="fa fa-map-marker"/> Chaguanas, Trinidad &amp; Scarborough, Tobago</p></div><div class="tf-info-card"><h2>BUSINESS HOURS</h2><p>Monday–Friday: 9:00 AM–5:00 PM</p><p>Saturday: 10:00 AM–2:00 PM</p><p>Sunday: Closed</p></div></aside></section>
            <section class="tf-section tf-container"><h2 class="tf-left-heading">OUR LOCATIONS</h2><div class="tf-location-grid"><article class="tf-location-card" t-foreach="locations" t-as="location"><img t-att-src="'/web/image/techflex.location/%s/image_1920' % location.id" t-att-alt="location.name"/><div><h3 t-out="location.name"/><p t-out="location.address"/><p><i class="fa fa-phone"/> <span t-out="location.phone"/></p><p><i class="fa fa-envelope"/> <span t-out="location.email"/></p><a t-att-href="location.map_url or '#'">View Location →</a></div></article></div></section>
            <section class="tf-cta-bar tf-container"><div><i class="fa fa-commenting"/><span><b>LET’S TALK TECH.</b><small>Call or message us today.</small></span></div><a class="tf-button tf-button-orange" href="tel:+18682354919">Call Now</a><a class="tf-button tf-button-outline-light" href="mailto:info@techflextt.com">Email Us</a></section>
        </div></t>
    </template>
</odoo>

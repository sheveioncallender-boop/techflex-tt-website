<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="techflex_shop_design" inherit_id="website_sale.products" name="TechFlex Shop Design" priority="80">
        <xpath expr="//div[@id='wrap']" position="attributes"><attribute name="class" add="tf-shop-page" separator=" "/></xpath>
        <xpath expr="//div[@id='o_wsale_container']" position="before">
            <section class="tf-shop-hero">
                <div class="tf-container tf-shop-hero-inner"><div><p class="tf-eyebrow">SHOP TECHFLEX</p><h1><t t-if="category" t-out="category.name"/><t t-else="">ALL THE TECH YOU NEED.</t><br/><em>ONE TRUSTED PLACE.</em></h1><p>Explore laptops, desktops, networking, printers, accessories and more while keeping Odoo’s complete eCommerce functionality.</p><div class="tf-mini-benefits"><span><i class="fa fa-shield"/> Quality Products</span><span><i class="fa fa-tags"/> Great Prices</span><span><i class="fa fa-truck"/> Fast Delivery</span><span><i class="fa fa-headphones"/> Expert Support</span></div></div><div class="tf-shop-hero-image"><img src="/techflex_tt_website/static/src/img/store_desktops.webp" alt="TechFlex products"/><div class="tf-wedge tf-wedge-right"/></div></div>
            </section>
        </xpath>
        <xpath expr="//div[@id='o_wsale_pager']" position="after">
            <section class="tf-shop-trust"><div><i class="fa fa-lock"/><span><b>Secure Shopping</b><small>Safe and secure checkout.</small></span></div><div><i class="fa fa-truck"/><span><b>Fast Delivery</b><small>Across Trinidad &amp; Tobago.</small></span></div><div><i class="fa fa-headphones"/><span><b>Expert Support</b><small>Before and after purchase.</small></span></div></section>
        </xpath>
    </template>

    <template id="techflex_product_design" inherit_id="website_sale.product" name="TechFlex Product Design" priority="80">
        <xpath expr="//div[@id='wrap']" position="attributes"><attribute name="class" add="tf-product-page" separator=" "/></xpath>
        <xpath expr="//div[@id='wrap']" position="inside">
            <section class="tf-product-trust tf-container"><div><i class="fa fa-shield"/><span><b>Secure Shopping</b><small>Your data is safe and secure.</small></span></div><div><i class="fa fa-truck"/><span><b>Delivery Across T&amp;T</b><small>Fast, reliable delivery.</small></span></div><div><i class="fa fa-headphones"/><span><b>Local Support</b><small>Expert advice and after-sales support.</small></span></div></section>
            <section class="tf-product-extra tf-container" t-if="product.techflex_show_details and (product.techflex_spec_line_ids or product.techflex_highlight_line_ids or product.techflex_warranty_details)">
                <div class="tf-product-tabs">
                    <div class="tf-product-description"><h2>DESCRIPTION &amp; HIGHLIGHTS</h2><div t-field="product.description_ecommerce"/><ul t-if="product.techflex_highlight_line_ids" class="tf-check-list"><li t-foreach="product.techflex_highlight_line_ids" t-as="highlight" t-out="highlight.name"/></ul></div>
                    <div class="tf-spec-table" t-if="product.techflex_spec_line_ids"><h2>TECHNICAL SPECIFICATIONS</h2><div class="tf-spec-row" t-foreach="product.techflex_spec_line_ids" t-as="spec" t-if="spec.show_on_website"><b t-out="spec.name"/><span t-out="spec.value"/></div></div>
                </div>
                <div class="tf-warranty-panel" t-if="product.techflex_warranty_label or product.techflex_warranty_details"><i class="fa fa-shield"/><div><h2 t-out="product.techflex_warranty_label or 'Warranty &amp; Support'"/><div t-field="product.techflex_warranty_details"/><p t-if="product.techflex_support_note"><b>Support:</b> <span t-out="product.techflex_support_note"/></p><p t-if="product.techflex_delivery_note"><b>Delivery:</b> <span t-out="product.techflex_delivery_note"/></p></div></div>
            </section>
            <section class="tf-cta-bar tf-container"><div><i class="fa fa-headphones"/><span><b>NEED HELP CHOOSING TECH?</b><small>Our team can help you find the right solution.</small></span></div><a class="tf-button tf-button-orange" href="/contact-us">Talk to an Expert</a><a class="tf-button tf-button-outline-light" href="tel:+18682354919">Call Us</a></section>
        </xpath>
    </template>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_techflex_contact_request_list" model="ir.ui.view">
        <field name="name">techflex.contact.request.list</field><field name="model">techflex.contact.request</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'new'" decoration-success="state == 'done'">
                <field name="name"/><field name="create_date"/><field name="full_name"/>
                <field name="email"/><field name="phone"/><field name="department"/><field name="subject"/><field name="state"/>
            </list>
        </field>
    </record>
    <record id="view_techflex_contact_request_form" model="ir.ui.view">
        <field name="name">techflex.contact.request.form</field><field name="model">techflex.contact.request</field>
        <field name="arch" type="xml">
            <form>
                <header><field name="state" widget="statusbar"/></header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group><group><field name="full_name"/><field name="email" widget="email"/><field name="phone" widget="phone"/></group>
                    <group><field name="department"/><field name="subject"/><field name="website_id"/><field name="submitted_from_website"/></group></group>
                    <group string="Message"><field name="message" nolabel="1"/></group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_techflex_contact_request" model="ir.actions.act_window">
        <field name="name">Contact Requests</field><field name="res_model">techflex.contact.request</field><field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_techflex_contact_requests" name="Contact Requests" parent="menu_techflex_requests" action="action_techflex_contact_request" sequence="20"/>
</odoo>
